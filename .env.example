# Copy to .env and adjust for your environment.

# Container socket for failure-runner service.
# Docker (default — works on Linux, macOS Docker Desktop, Windows Docker Desktop):
# DOCKER_SOCKET=/var/run/docker.sock

# Podman rootless on Linux (replace 1000 with your UID: `id -u`):
# DOCKER_SOCKET=/run/user/1000/podman/podman.sock

# Podman rootless on macOS:
# DOCKER_SOCKET=/var/run/docker.sock  (podman machine creates a compat socket here)
